# ─── Required ───────────────────────────────────────────────
# Session signing key (generate with: openssl rand -base64 32)
AUTH_SECRET=

# At-rest encryption key for admin-configured secrets (API keys,
# PATs, webhook secrets). Must be different from AUTH_SECRET in a
# hardened setup — see SECURITY.md. If unset, falls back to
# AUTH_SECRET for backward compatibility (a startup warning logs).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Trust the host header (set to "true" behind a reverse proxy)
AUTH_TRUST_HOST=true

# ─── Database ───────────────────────────────────────────────
# Path to SQLite database (defaults to data/db/ghostbot.sqlite)
# DATABASE_PATH=

# ─── LLM Provider ──────────────────────────────────────────
# Options: ollama, anthropic, openai, google
# LLM_PROVIDER=ollama

# Ollama base URL (only needed if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434

# Model name (auto-detected if empty)
# LLM_MODEL=

# ─── API Keys (configured via Admin UI, stored encrypted) ──
# These are NOT needed in .env — use the admin panel instead:
#   - Anthropic API key
#   - OpenAI API key
#   - Google AI API key
#   - GitHub PAT (GH_TOKEN)
#   - Telegram bot token
#   - Slack bot token

# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Docker daemon endpoint ────────────────────────────────
# GhostBot launches coding-agent containers via the Docker API.
# For defense in depth, route all Docker API traffic through the
# docker-socket-proxy defined in docker-compose.yml (the default).
# Only override if you are self-hosting without compose and know the
# trade-off (bind-mounting /var/run/docker.sock gives the app host
# root). See SECURITY.md.
DOCKER_HOST=tcp://docker-proxy:2375

# ─── Agent container resource limits (Phase 3.2) ───────────
# Defaults are sized for solo / small-team use. Bump for large repos.
# AGENT_MEMORY_LIMIT_MB=2048
# AGENT_CPU_LIMIT=1
# AGENT_PIDS_LIMIT=256
# AGENT_TIMEOUT_SEC=900
