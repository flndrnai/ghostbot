# ─── Required ───────────────────────────────────────────────
# Session encryption key (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Trust the host header (set to "true" behind a reverse proxy)
AUTH_TRUST_HOST=true

# ─── Database ───────────────────────────────────────────────
# Path to SQLite database (defaults to data/db/ghostbot.sqlite)
# DATABASE_PATH=

# ─── LLM Provider ──────────────────────────────────────────
# Options: ollama, anthropic, openai, google
# LLM_PROVIDER=ollama

# Ollama base URL (only needed if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434

# Model name (auto-detected if empty)
# LLM_MODEL=

# ─── API Keys (configured via Admin UI, stored encrypted) ──
# These are NOT needed in .env — use the admin panel instead:
#   - Anthropic API key
#   - OpenAI API key
#   - Google AI API key
#   - GitHub PAT (GH_TOKEN)
#   - Telegram bot token
#   - Slack bot token

# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
